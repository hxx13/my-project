<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.modules.supplies.mapper.SupplyOperationLogMapper">

    <resultMap id="Base" type="com.example.demo.modules.supplies.entity.SupplyOperationLog">
        <id property="id" column="id"/>
        <result property="opType" column="op_type"/>
        <result property="refType" column="ref_type"/>
        <result property="refId" column="ref_id"/>
        <result property="operatorUserId" column="operator_user_id"/>
        <result property="detailJson" column="detail_json"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO supply_operation_log(op_type, ref_type, ref_id, operator_user_id, detail_json, created_at)
        VALUES (#{opType}, #{refType}, #{refId}, #{operatorUserId}, #{detailJson}, #{createdAt})
    </insert>

    <select id="listPaged" resultMap="Base">
        SELECT * FROM supply_operation_log
        <where>
            <if test="opType != null and opType != ''">
                AND op_type = #{opType}
            </if>
        </where>
        ORDER BY id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(1) FROM supply_operation_log
        <where>
            <if test="opType != null and opType != ''">
                AND op_type = #{opType}
            </if>
        </where>
    </select>
</mapper>
