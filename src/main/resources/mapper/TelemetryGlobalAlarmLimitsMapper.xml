<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.modules.telemetry.mapper.TelemetryGlobalAlarmLimitsMapper">

    <resultMap id="RowMap" type="com.example.demo.modules.telemetry.entity.TelemetryGlobalAlarmLimitsRow">
        <id column="id" property="id"/>
        <result column="temp_min" property="tempMin"/>
        <result column="temp_max" property="tempMax"/>
        <result column="hum_min" property="humMin"/>
        <result column="hum_max" property="humMax"/>
        <result column="pressure_min" property="pressureMin"/>
        <result column="pressure_max" property="pressureMax"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectSingleton" resultMap="RowMap">
        SELECT id, temp_min, temp_max, hum_min, hum_max, pressure_min, pressure_max, updated_at
        FROM telemetry_global_alarm_limits
        WHERE id = 1
        LIMIT 1
    </select>

    <insert id="insertSingletonIfMissing">
        INSERT IGNORE INTO telemetry_global_alarm_limits (id) VALUES (1)
    </insert>

    <update id="updateSingleton">
        UPDATE telemetry_global_alarm_limits
        SET temp_min = #{tempMin},
            temp_max = #{tempMax},
            hum_min = #{humMin},
            hum_max = #{humMax},
            pressure_min = #{pressureMin},
            pressure_max = #{pressureMax},
            updated_at = CURRENT_TIMESTAMP
        WHERE id = 1
    </update>
</mapper>
